# Copier ce fichier en .env et remplir les valeurs

# Une ou plusieurs clés Groq (rotation auto si quota/limite atteint)
GROQ_API_KEY=your_groq_api_key_here
# GROQ_API_KEY=gsk_key1,gsk_key2,gsk_key3
PAYMENT_MODE=simulated

SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_PROJECT_ID=YOUR_PROJECT_ID
SUPABASE_DB_HOST=db.YOUR_PROJECT_ID.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_secret_or_service_role_key_here

# Mot de passe PostgreSQL (Settings → Database → Database password)
# Requis pour: python scripts/run_migrations.py
SUPABASE_DB_PASSWORD=
